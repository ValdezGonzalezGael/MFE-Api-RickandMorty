# Variable del npmbre del repo
VITE_APP_NAME=MF-Characters

# Puerto en el que se levanta el mfe
VITE_PORT=3001

# Variable para las imagenes
VITE_NAME_IMAGE=mfe-contenedor/

# # Dirección IP del servidor
VITE_MYIP=localhost

# Variable https:
VITE_HTTPS=http

# URLs de los remotos que pueden ser consumidos en este paquete
VITE_REMOTE_ENTRY_CHARACTER_DETAIL=${VITE_HTTPS}://${VITE_MYIP}:3002/MF-CharacterDetail/assets/remoteEntry.js
VITE_REMOTE_ENTRY_CONTAINER=${VITE_HTTPS}://${VITE_MYIP}:3000/mfe-contenedor/assets/remoteEntry.js